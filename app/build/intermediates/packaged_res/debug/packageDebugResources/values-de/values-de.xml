<?xml version="1.0" encoding="utf-8"?>
<resources>
    <string name="accessibility_service_description">TouchFix behebt automatisch das Touch-Freeze-Problem nach dem Aufwachen des Pixel 10 Pro. Der Service erkennt Screen-On-Events und setzt den Touch-Classifier zurück, wenn nötig.</string>
    <string name="app_name">TouchFix</string>
    <string name="btn_activate">Service aktivieren</string>
    <string name="btn_clear">Löschen</string>
    <string name="btn_service_enable_now">Service jetzt aktivieren</string>
    <string name="btn_service_settings">Service-Einstellungen öffnen</string>
    <string name="desc_escalating">Intelligenter Watchdog: Eskaliert durch 4 Stufen wenn Touch tot ist.</string>
    <string name="desc_hal_restart">Versucht den Touch-HAL-Service (Vendor-Treiber) neu zu starten. Aggressivster Ansatz.</string>
    <string name="desc_phantom_swipe">Injiziert bei Screen-On sofort 6 Swipes/Taps statt punktueller Events. Durchläuft die gesamte Touch-Pipeline.</string>
    <string name="desc_post_fingerprint">Gezielter 4-Stufen-Reset nach Fingerprint-Unlock (50/300/600/1000ms). Erkennt ob Touch nach dem Entsperren funktioniert und reagiert.</string>
    <string name="desc_sysfs_reset">Schreibt direkt auf Hardware-Reset-Nodes des Touch-Controllers (Goodix/Pixel). Braucht ggf. Root.</string>
    <string name="info_text">v14 fokussiert auf das Fingerprint-Unlock-Problem. Post-Fingerprint Reset erkennt den genauen Zeitpunkt des Entsperrens und reagiert gezielt.</string>
