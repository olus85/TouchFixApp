<resources>
    <string name="app_name">TouchFix</string>
    <string name="accessibility_service_description">TouchFix automatically fixes the touch freeze issue after waking up the Pixel 10 Pro. The service detects Screen-On events and resets the touch classifier if necessary.</string>
    
    <!-- Service Status -->
    <string name="status_service_active">TouchFix v14 ACTIVE</string>
    <string name="status_service_inactive">TouchFix Service NOT active</string>
    <string name="btn_service_settings">Open Service Settings</string>
    <string name="btn_service_enable_now">Activate Service Now</string>
    
    <!-- Permission -->
    <string name="status_permission_granted">WRITE_SECURE_SETTINGS granted</string>
    <string name="status_permission_missing">WRITE_SECURE_SETTINGS missing\n\nVia ADB:\nadb shell pm grant de.olus.touchfix android.permission.WRITE_SECURE_SETTINGS</string>
    
    <!-- UI Labels -->
    <string name="label_service_status">SERVICE STATUS</string>
    <string name="label_permission">PERMISSION</string>
    <string name="label_fix_options">FIX OPTIONS</string>
    <string name="label_console">CONSOLE</string>
    <string name="label_stats">STATISTICS</string>
    <string name="label_checking">Checking...</string>
    <string name="label_waiting_events">Waiting for events...</string>
    <string name="btn_clear">Clear</string>
    <string name="btn_activate">Activate Service</string>
    <string name="info_text">v14 focuses on the fingerprint unlock issue. Post-Fingerprint Reset detects the exact timing of unlocking and reacts specifically.</string>
    
    <!-- Fix Options -->
    <string name="title_post_fingerprint">Post-Fingerprint Reset</string>
    <string name="desc_post_fingerprint">Targeted 4-stage reset after fingerprint unlock (50/300/600/1000ms). Detects if touch works after unlocking and reacts.</string>
    <string name="title_hal_restart">Touch HAL Restart</string>
    <string name="desc_hal_restart">Attempts to restart the Touch HAL service (vendor driver). Most aggressive approach.</string>
    <string name="title_phantom_swipe">Phantom Swipe Flood</string>
    <string name="desc_phantom_swipe">Injects 6 diverse swipe gestures immediately at Screen-On instead of point events. Exercises the entire touch pipeline.</string>
    <string name="title_sysfs_reset">sysfs Touch Reset</string>
    <string name="desc_sysfs_reset">Writes directly to hardware reset nodes of the touch controller (Goodix/Pixel). May need root.</string>
    <string name="title_escalating">Escalating Auto-Fix</string>
    <string name="desc_escalating">Intelligent Watchdog: Escalates through 4 levels if touch is dead.</string>

    <!-- Notifications & Logs -->
    <string name="notification_channel_name">TouchFix Status</string>
