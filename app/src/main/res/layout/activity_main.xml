<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FF1C1B1F"
    android:padding="24dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal">

        <!-- App Title -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🔧 TouchFix"
            android:textSize="32sp"
            android:textColor="#FFE6E1E5"
            android:textStyle="bold"
            android:layout_marginTop="32dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="v14 · Pixel 10 Pro · International Edition"
            android:textSize="14sp"
            android:textColor="#99E6E1E5"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="32dp" />

        <!-- Service Status Card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/card_background"
            android:padding="20dp"
            android:layout_marginBottom="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/label_service_status"
                android:textSize="12sp"
                android:textColor="#99E6E1E5"
                android:letterSpacing="0.1"
                android:layout_marginBottom="8dp" />

            <TextView
                android:id="@+id/status_service"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/label_checking"
                android:textSize="16sp"
                android:textColor="#FFE6E1E5" />
        </LinearLayout>

        <!-- Permission Status Card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/card_background"
            android:padding="20dp"
            android:layout_marginBottom="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/label_permission"
                android:textSize="12sp"
                android:textColor="#99E6E1E5"
                android:letterSpacing="0.1"
                android:layout_marginBottom="8dp" />

            <TextView
                android:id="@+id/status_permission"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/label_checking"
                android:textSize="14sp"
                android:textColor="#FFE6E1E5"
                android:fontFamily="monospace" />
        </LinearLayout>

        <!-- Fix Switches Card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/card_background"
            android:padding="20dp"
            android:layout_marginBottom="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/label_fix_options"
                android:textSize="12sp"
                android:textColor="#FF80CBC4"
                android:letterSpacing="0.1"
                android:layout_marginBottom="14dp" />

            <!-- 1. Post-Fingerprint Reset -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="4dp">
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/title_post_fingerprint"
                    android:textSize="14sp"
                    android:textColor="#FFFFAB40" />
                <Switch
                    android:id="@+id/switch_post_fingerprint"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content" />
            </LinearLayout>
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/desc_post_fingerprint"
                android:textSize="11sp"
                android:textColor="#99FFAB40"
                android:layout_marginBottom="16dp" />

            <!-- 2. Touch HAL Restart -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="4dp">
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/title_hal_restart"
                    android:textSize="14sp"
                    android:textColor="#FFE6E1E5" />
                <Switch
                    android:id="@+id/switch_hal_restart"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content" />
            </LinearLayout>
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/desc_hal_restart"
                android:textSize="11sp"
                android:textColor="#66E6E1E5"
                android:layout_marginBottom="16dp" />

            <!-- 3. Phantom Swipe -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="4dp">
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/title_phantom_swipe"
                    android:textSize="14sp"
                    android:textColor="#FFE6E1E5" />
                <Switch
                    android:id="@+id/switch_phantom_swipe"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content" />
            </LinearLayout>
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/desc_phantom_swipe"
                android:textSize="11sp"
                android:textColor="#66E6E1E5"
                android:layout_marginBottom="16dp" />

            <!-- 4. sysfs Touch Reset -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="4dp">
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/title_sysfs_reset"
                    android:textSize="14sp"
                    android:textColor="#FFE6E1E5" />
                <Switch
                    android:id="@+id/switch_sysfs_reset"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content" />
            </LinearLayout>
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/desc_sysfs_reset"
                android:textSize="11sp"
                android:textColor="#66E6E1E5"
                android:layout_marginBottom="16dp" />

            <!-- 5. Escalating Auto-Fix -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="4dp">
                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/title_escalating"
                    android:textSize="14sp"
                    android:textColor="#FFFFAB40" />
                <Switch
                    android:id="@+id/switch_escalating"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content" />
            </LinearLayout>
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/desc_escalating"
                android:textSize="11sp"
                android:textColor="#99FFAB40" />
        </LinearLayout>

        <!-- CONSOLE Card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/card_background"
            android:padding="20dp"
            android:layout_marginBottom="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="8dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/label_console"
                    android:textSize="12sp"
                    android:textColor="#FF80CBC4"
                    android:letterSpacing="0.1" />

                <Button
                    android:id="@+id/btn_clear_log"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:text="@string/btn_clear"
                    android:textSize="11sp"
                    android:backgroundTint="#33E6E1E5"
                    android:textColor="#99E6E1E5"
                    android:minWidth="0dp"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp" />
            </LinearLayout>

            <ScrollView
                android:id="@+id/console_scroll"
                android:layout_width="match_parent"
                android:layout_height="300dp"
                android:background="#FF121212"
                android:padding="10dp">

                <TextView
                    android:id="@+id/console_text"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/label_waiting_events"
                    android:textSize="11sp"
                    android:textColor="#CCCCCCCC"
                    android:fontFamily="monospace"
                    android:lineSpacingMultiplier="1.3" />
            </ScrollView>
        </LinearLayout>

        <!-- Stats Card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/card_background"
            android:padding="20dp"
            android:layout_marginBottom="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/label_stats"
                android:textSize="12sp"
                android:textColor="#99E6E1E5"
                android:letterSpacing="0.1"
                android:layout_marginBottom="8dp" />

            <TextView
                android:id="@+id/status_log"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="–"
                android:textSize="14sp"
                android:textColor="#FFE6E1E5"
                android:fontFamily="monospace" />
        </LinearLayout>

        <!-- Enable Button -->
        <Button
            android:id="@+id/btn_enable_service"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="@string/btn_activate"
            android:textSize="16sp"
            android:layout_marginTop="8dp"
            android:backgroundTint="#FF6750A4" />

        <!-- Info -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/info_text"
            android:textSize="12sp"
            android:textColor="#66E6E1E5"
            android:layout_marginTop="24dp"
            android:layout_marginBottom="32dp"
            android:lineSpacingMultiplier="1.4" />

    </LinearLayout>
</ScrollView>
